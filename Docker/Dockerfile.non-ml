# ============================================================
# Image 2: Python + R
# Base: Ubuntu 22.04
#
# Includes: Miniforge (conda + mamba), Python 3.11, R 4.x.
# Users can conda/pip install / install.packages() at runtime.
# ============================================================

FROM ubuntu:22.04

# ── System metadata ─────────────────────────────────────────
LABEL maintainer="berkeley-mids"
LABEL description="Non-ML Research environment: Miniforge, Python 3.11, R 4.x"

# ── Prevent interactive prompts during apt ──────────────────
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# ── System packages ─────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Core utilities
    wget curl git vim nano less \
    ca-certificates gnupg software-properties-common \
    # Build tools
    build-essential gcc g++ make gfortran \
    # Compression / archive
    zip unzip tar \
    # R runtime dependencies
    libcurl4-openssl-dev libssl-dev libxml2-dev \
    libfontconfig1-dev libharfbuzz-dev libfribidi-dev \
    libfreetype6-dev libpng-dev libtiff5-dev libjpeg-dev \
    liblapack-dev libopenblas-dev \
    # Sudo for runtime installs
    sudo \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js 20 LTS ──────────────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── Miniforge (conda + mamba, Python 3.11) ──────────────────
ENV CONDA_DIR=/opt/conda
RUN wget -qO /tmp/miniforge.sh \
    "https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-$(uname -m).sh" \
    && bash /tmp/miniforge.sh -b -p "$CONDA_DIR" \
    && rm /tmp/miniforge.sh \
    && $CONDA_DIR/bin/conda install -y python=3.11 \
    && $CONDA_DIR/bin/conda clean -afy

ENV PATH="$CONDA_DIR/bin:$PATH"

# ── R 4.x from CRAN PPA ──────────────────────────────────────
RUN wget -qO- https://cloud.r-project.org/bin/linux/ubuntu/marutter_pubkey.asc \
    | gpg --dearmor -o /usr/share/keyrings/r-project.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/r-project.gpg] https://cloud.r-project.org/bin/linux/ubuntu jammy-cran40/" \
    > /etc/apt/sources.list.d/r-project.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends r-base r-base-dev \
    && rm -rf /var/lib/apt/lists/*

# ── R packages ───────────────────────────────────────────────
RUN Rscript -e " \
    install.packages(c( \
        # Tidyverse stack \
        'tidyverse', 'haven', 'readxl', 'janitor', \
        # Output / tables \
        'stargazer', 'modelsummary', 'gt', 'knitr', 'rmarkdown', \
        # Misc \
        'ggplot2', 'patchwork', 'data.table', 'Rcpp' \
    ), repos='https://cloud.r-project.org', Ncpus=4) \
"

# ── Python scientific stack ──────────────────────────────────
RUN pip install --no-cache-dir \
    # Core scientific
    numpy scipy pandas matplotlib seaborn \
    # Stats
    statsmodels \
    # Data I/O
    pyreadstat openpyxl xlrd \
    # Notebooks
    jupyter jupyterlab ipywidgets

# ── Codex CLI ────────────────────────────────────────────────
RUN npm install -g @openai/codex

# ── Docent runtime helpers ───────────────────────────────────
RUN pip install --no-cache-dir docent-python
COPY docent/ /opt/rct/

# ── Session entrypoint scripts (RunPod auto-start) ──────────
COPY Docker/start-session.sh /opt/rct/start-session.sh
COPY Docker/finish-session.sh /opt/rct/finish-session.sh
RUN chmod +x /opt/rct/start-session.sh /opt/rct/finish-session.sh \
    && ln -s /opt/rct/finish-session.sh /usr/local/bin/finish-session

# ── Non-root user ────────────────────────────────────────────
ARG USERNAME=researcher
ARG UID=1000
RUN useradd -m -u $UID -s /bin/bash $USERNAME \
    && echo "$USERNAME ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# ── Auto-start session on first interactive login ────────────
# Works for both root (RunPod default) and researcher (local/Lambda)
RUN BASHRC_SNIPPET='# Auto-start reproducibility session on first connect\nif [ -t 0 ] && [ ! -f /tmp/.rct_session_started ]; then\n    source /opt/rct/start-session.sh\nfi' \
    && echo -e "\n$BASHRC_SNIPPET" >> /root/.bashrc \
    && echo -e "\n$BASHRC_SNIPPET" >> /home/$USERNAME/.bashrc

WORKDIR /workspace
RUN conda init bash \
    && su -c "$CONDA_DIR/bin/conda init bash" $USERNAME

# ── Environment variables ────────────────────────────────────
ENV PATH="$CONDA_DIR/bin:$PATH"
ENV PYTHONUNBUFFERED=1

# ── Default command (RunPod template: sleep infinity) ────────
CMD ["sleep", "infinity"]

# ── Build and run ────────────────────────────────────────────
# Build (from repo root):
#   docker buildx build --platform linux/amd64,linux/arm64 \
#     -f Docker/Dockerfile.non-ml \
#     -t ashetty21/non-ml:latest \
#     --push .
#
# RunPod: set this image as template, start command "sleep infinity",
#         set env vars PAPER_NAME, RESEARCHER, CONDITION, DOCENT_API_KEY
#
# Local:
#   docker run -it -v $(pwd):/workspace ashetty21/non-ml:latest bash
